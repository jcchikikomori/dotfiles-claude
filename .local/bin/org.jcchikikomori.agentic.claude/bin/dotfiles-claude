#!/bin/sh

set -eu

# dotfiles-claude — install Claude Code MCP dependencies
# https://docs.anthropic.com/en/docs/claude-code
#
# Usage: dotfiles-claude <command> [options]
#
# Commands:
#   install-mcps [--global|--local]  Install MCPs from registry (default: local)
#   add-global <mcp-name>            Add MCP to global config (all projects)
#   add-local <mcp-name>             Add MCP to local config (current project)
#   list-available                   List MCPs available in shared registry
#   list                             List currently configured MCPs
#   sync-from-opencode               Import MCPs from OpenCode config

# Source .profile.local for environment variables (MCP tokens, etc.)
if [ -f "$HOME/.profile.local" ]; then
    . "$HOME/.profile.local"
fi

CLAUDE_SETTINGS="$HOME/.claude/settings.json"
CLAUDE_JSON="$HOME/.claude.json"

# Determine dotfiles path for shared MCP registry
if [ -n "${DOTFILES_PATH:-}" ]; then
    DOTFILES_DIR="$DOTFILES_PATH"
elif [ -d "$HOME/.dotfiles" ]; then
    DOTFILES_DIR="$HOME/.dotfiles"
else
    DOTFILES_DIR="$(dirname "$(dirname "$(dirname "$(dirname "$(dirname "$(cd -- "$(dirname -- "$0")" && pwd)")")")")")"
fi

# Check for local mcps.json first, then fall back to shared registry
# Script is at: linux/claude/.local/bin/org.jcchikikomori.agentic.claude/bin/dotfiles-claude
# mcps.json is at: linux/claude/mcps.json (4 levels up from script)
SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
CLAUDE_DIR="$(dirname "$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")")"
LOCAL_MCPS_FILE="${CLAUDE_DIR}/mcps.json"
SHARED_MCPS_FILE="${DOTFILES_DIR}/shared/ai-agents/mcps.json"

# Use local mcps.json if it exists, otherwise use shared
if [ -f "$LOCAL_MCPS_FILE" ]; then
    MCPS_FILE="$LOCAL_MCPS_FILE"
else
    MCPS_FILE="$SHARED_MCPS_FILE"
fi

# Scope configuration
SCOPE="local"  # default scope

_is_installed() {
    command -v claude > /dev/null 2>&1
}

_detect_distro() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "${ID:-unknown}"
    else
        echo "unknown"
    fi
}

_is_termux() {
    [ -n "${PREFIX:-}" ] && echo "$PREFIX" | grep -q "com.termux"
}

# ─── JSON helpers ─────────────────────────────────────────────────────────────

_json_tool() {
    if command -v jq > /dev/null 2>&1; then
        echo "jq"
    elif command -v python3 > /dev/null 2>&1; then
        echo "python3"
    else
        echo "none"
    fi
}

# ─── MCP Registry ─────────────────────────────────────────────────────────────
# Read MCPs from shared registry or fallback to inline definition

_get_mcp_from_registry() {
    mcp_name="$1"

    # Check if registry exists
    if [ ! -f "$MCPS_FILE" ]; then
        return 1
    fi

    json_tool=$(_json_tool)

    case "$json_tool" in
        jq)
            jq -r --arg name "$mcp_name" '.mcpServers[$name] // empty' "$MCPS_FILE" 2>/dev/null
            ;;
        python3)
            python3 -c "
import json
import sys
try:
    with open('$MCPS_FILE') as f:
        data = json.load(f)
    mcp = data.get('mcpServers', {}).get('$mcp_name')
    if mcp:
        print(json.dumps(mcp))
except Exception:
    pass
"
            ;;
        *)
            return 1
            ;;
    esac
}

_list_available_mcps() {
    if [ ! -f "$MCPS_FILE" ]; then
        echo "  [warn] MCP registry not found: $MCPS_FILE"
        return 1
    fi

    json_tool=$(_json_tool)

    echo "  Available MCPs from registry:"
    echo ""

    case "$json_tool" in
        jq)
            jq -r '.mcpServers | to_entries[] | "  • \(.key) - \(.value.description // "No description")"' "$MCPS_FILE"
            ;;
        python3)
            python3 -c "
import json
try:
    with open('$MCPS_FILE') as f:
        data = json.load(f)
    for name, mcp in data.get('mcpServers', {}).items():
        desc = mcp.get('description', 'No description')
        print(f'  • {name} - {desc}')
except Exception as e:
    print(f'  [error] Failed to read registry: {e}')
"
            ;;
        *)
            echo "  [warn] No JSON tool available (install jq or python3)"
            ;;
    esac
}

# ─── MCP helpers ──────────────────────────────────────────────────────────────

# Check if MCP is already configured in Claude
_mcp_exists() {
    mcp_name="$1"
    claude mcp list 2>/dev/null | grep -q "^$mcp_name " && return 0
    return 1
}

# Install a single MCP
_install_mcp() {
    line="$1"
    [ -z "$line" ] && return 0

    mcp_name=$(echo "$line" | cut -d'|' -f1)
    mcp_type=$(echo "$line" | cut -d'|' -f2)
    mcp_command=$(echo "$line" | cut -d'|' -f3)
    mcp_env=$(echo "$line" | cut -d'|' -f4)

    # Check if already configured
    if _mcp_exists "$mcp_name"; then
        echo "  [ok]      $mcp_name  (already configured)"
        _report_env "$mcp_name" "$mcp_env"
        return 0
    fi

    case "$mcp_type" in
        npx)
            if ! command -v npx > /dev/null 2>&1; then
                echo "  [warn]    $mcp_name  needs npx — install Node.js/npm first"
                return 0
            fi
            echo "  [add]     $mcp_name  via npx..."
            # Extract the package from npx command (npx -y <package>)
            npx_pkg=$(echo "$mcp_command" | sed 's/npx -y //')
            if _add_mcp_with_env "$mcp_name" "$mcp_command" "$mcp_env"; then
                echo "  [done]    $mcp_name  added"
            else
                echo "  [fail]    $mcp_name  failed to add"
            fi
            ;;
        uvx)
            if ! command -v uvx > /dev/null 2>&1; then
                echo "  [warn]    $mcp_name  needs uvx — install uv first"
                return 0
            fi
            echo "  [add]     $mcp_name  via uvx..."
            if _add_mcp_with_env "$mcp_name" "$mcp_command" "$mcp_env"; then
                echo "  [done]    $mcp_name  added"
            else
                echo "  [fail]    $mcp_name  failed to add"
            fi
            ;;
        pipx)
            # First ensure binary is installed
            binary_name=$(echo "$mcp_command" | awk '{print $1}')
            if ! command -v "$binary_name" > /dev/null 2>&1; then
                echo "  [pipx]    $mcp_name  installing '$binary_name' via pipx..."
                if pipx install "$binary_name" 2>&1 | sed 's/^/              /'; then
                    echo "  [done]    $mcp_name  binary installed"
                else
                    echo "  [fail]    $mcp_name  pipx install failed"
                    return 0
                fi
            fi
            # Now add to Claude
            echo "  [add]     $mcp_name  to Claude..."
            if _add_mcp_with_env "$mcp_name" "$mcp_command" "$mcp_env"; then
                echo "  [done]    $mcp_name  added"
            else
                echo "  [fail]    $mcp_name  failed to add"
            fi
            ;;
        docker)
            if ! command -v docker > /dev/null 2>&1; then
                echo "  [warn]    $mcp_name  needs docker — install Docker first"
                return 0
            fi
            echo "  [add]     $mcp_name  via docker..."
            if _add_mcp_with_env "$mcp_name" "$mcp_command" "$mcp_env"; then
                echo "  [done]    $mcp_name  added"
            else
                echo "  [fail]    $mcp_name  failed to add"
            fi
            ;;
        http)
            echo "  [add]     $mcp_name  (HTTP server)..."
            _add_mcp_http "$mcp_name" "$mcp_command" "$mcp_env"
            ;;
        *)
            echo "  [skip]    $mcp_name  (unknown type: $mcp_type)"
            ;;
    esac

    _report_env "$mcp_name" "$mcp_env"
}

# Add MCP with environment variables
# Usage: _add_mcp_with_env <name> <command> <env_keys>
_add_mcp_with_env() {
    mcp_name="$1"
    mcp_command="$2"
    mcp_env="$3"

    # Build env flags
    env_flags=""
    if [ -n "$mcp_env" ]; then
        old_ifs="$IFS"
        IFS=","
        for key in $mcp_env; do
            IFS="$old_ifs"
            [ -z "$key" ] && continue
            # Get value from environment
            val=""
            eval "val=\${${key}:-}"
            if [ -n "$val" ]; then
                if [ -z "$env_flags" ]; then
                    env_flags="-e $key=$val"
                else
                    env_flags="$env_flags -e $key=$val"
                fi
            fi
            IFS=","
        done
        IFS="$old_ifs"
    fi

    # Add MCP using claude CLI
    # Note: Claude CLI doesn't support --global flag, it always adds to current project
    # For global MCPs, we need to manually edit ~/.claude.json
    if [ "$SCOPE" = "global" ]; then
        _add_mcp_global "$mcp_name" "$mcp_command" "$mcp_env"
    else
        # Local scope - use CLI
        # Important: env flags must come AFTER the command, not before
        if [ -n "$env_flags" ]; then
            # shellcheck disable=SC2086
            claude mcp add "$mcp_name" $mcp_command $env_flags 2>&1 | sed 's/^/              /'
        else
            # shellcheck disable=SC2086
            claude mcp add "$mcp_name" $mcp_command 2>&1 | sed 's/^/              /'
        fi
    fi
}

# Add MCP to global config (all projects)
# This manually edits ~/.claude.json since CLI doesn't support global scope
_add_mcp_global() {
    mcp_name="$1"
    mcp_command="$2"
    mcp_env="$3"

    json_tool=$(_json_tool)

    if [ "$json_tool" = "none" ]; then
        echo "  [error]   Cannot add global MCP: jq or python3 required"
        return 1
    fi

    # Parse command into array
    cmd_array=""
    for arg in $mcp_command; do
        if [ -z "$cmd_array" ]; then
            cmd_array="\"$arg\""
        else
            cmd_array="$cmd_array, \"$arg\""
        fi
    done

    # Build env object
    env_obj="{}"
    if [ -n "$mcp_env" ]; then
        old_ifs="$IFS"
        IFS=","
        env_entries=""
        for key in $mcp_env; do
            IFS="$old_ifs"
            [ -z "$key" ] && continue
            val=""
            eval "val=\${${key}:-}"
            if [ -n "$val" ]; then
                if [ -z "$env_entries" ]; then
                    env_entries="\"$key\": \"$val\""
                else
                    env_entries="$env_entries, \"$key\": \"$val\""
                fi
            fi
            IFS=","
        done
        IFS="$old_ifs"
        if [ -n "$env_entries" ]; then
            env_obj="{$env_entries}"
        fi
    fi

    # Create MCP entry
    mcp_entry="{\"type\": \"stdio\", \"command\": $(echo "$mcp_command" | awk '{print $1}' | xargs -I{} echo "\"{}\""), \"args\": [$cmd_array], \"env\": $env_obj}"

    # Read existing config or create new
    if [ -f "$CLAUDE_JSON" ]; then
        case "$json_tool" in
            jq)
                # Check if MCP already exists globally
                if jq -e ".mcpServers.\"$mcp_name\"" "$CLAUDE_JSON" > /dev/null 2>&1; then
                    echo "              MCP '$mcp_name' already exists in global config"
                    return 0
                fi
                # Add to global mcpServers
                jq --arg name "$mcp_name" --argjson entry "$mcp_entry" '.mcpServers[$name] = $entry' "$CLAUDE_JSON" > "${CLAUDE_JSON}.tmp" && mv "${CLAUDE_JSON}.tmp" "$CLAUDE_JSON"
                ;;
            python3)
                python3 << EOF
import json
import sys

try:
    with open('$CLAUDE_JSON', 'r') as f:
        config = json.load(f)

    if 'mcpServers' not in config:
        config['mcpServers'] = {}

    if '$mcp_name' in config['mcpServers']:
        print("              MCP '$mcp_name' already exists in global config")
        sys.exit(0)

    # Parse the MCP entry
    mcp_data = json.loads('$mcp_entry')
    config['mcpServers']['$mcp_name'] = mcp_data

    with open('$CLAUDE_JSON', 'w') as f:
        json.dump(config, f, indent=2)
except Exception as e:
    print(f"              Error: {e}", file=sys.stderr)
    sys.exit(1)
EOF
                ;;
        esac
    else
        # Create new config with global MCP
        echo "{\"mcpServers\": {\"$mcp_name\": $mcp_entry}}" | jq '.' > "$CLAUDE_JSON"
    fi

    echo "              Added to global config (~/.claude.json)"
}

# Add HTTP MCP using claude mcp add-json command
# Usage: _add_mcp_http <name> <url> <env_keys>
_add_mcp_http() {
    mcp_name="$1"
    mcp_url="$2"
    mcp_env="$3"
    
    # Build JSON configuration
    if [ -n "$mcp_env" ]; then
        # Get token from environment
        token=""
        # Assume first env var is the token
        key=$(echo "$mcp_env" | cut -d',' -f1)
        eval "token=\${${key}:-}"
        
        if [ -z "$token" ]; then
            echo "              [error] No token found for $mcp_name"
            echo "              Set $key in ~/.profile.local"
            return 1
        fi
        
        # Build JSON with authentication
        json_config="{\"type\": \"http\", \"url\": \"$mcp_url\", \"headers\": {\"Authorization\": \"Bearer $token\"}}"
    else
        # No authentication required
        json_config="{\"type\": \"http\", \"url\": \"$mcp_url\"}"
    fi
    
    # Add scope flag if global
    scope_flag=""
    if [ "$SCOPE" = "global" ]; then
        scope_flag="--scope user"
    fi
    
    # Use claude mcp add-json command
    # shellcheck disable=SC2086
    if claude mcp add-json $scope_flag "$mcp_name" "$json_config" 2>&1 | sed 's/^/              /'; then
        echo "  [done]    $mcp_name added ($SCOPE scope)"
    else
        echo "  [fail]    $mcp_name failed to add"
        return 1
    fi
}

# Report ENV status
_report_env() {
    mcp_name="$1"
    env_keys="$2"
    [ -z "$env_keys" ] && return

    echo "            ENV for $mcp_name:"
    old_ifs="$IFS"
    IFS=","
    for key in $env_keys; do
        IFS="$old_ifs"
        [ -z "$key" ] && continue
        val=""
        eval "val=\${${key}:-}"
        if [ -n "$val" ]; then
            echo "              $key  → set ✓"
        else
            echo "              $key  → NOT SET  ← export in shell or add to ~/.zshrc"
        fi
        IFS=","
    done
    IFS="$old_ifs"
}

# ─── MCP dependency installer ─────────────────────────────────────────────────

# Read all MCPs from JSON registry and install them
_read_mcps_from_json() {
    if [ ! -f "$MCPS_FILE" ]; then
        echo "  [error] MCP registry not found: $MCPS_FILE"
        return 1
    fi

    json_tool=$(_json_tool)

    case "$json_tool" in
        jq)
            jq -r '.mcpServers | to_entries[] | 
                if .value.type == "http" then
                    "\(.key)|http|\(.value.url)|\(.value.env | join(","))"
                else
                    "\(.key)|\(.value.installMethod // "stdio")|\(.value.command) \(.value.args | join(" "))|\(.value.env | join(","))"
                end' "$MCPS_FILE" 2>/dev/null
            ;;
        python3)
            python3 -c "
import json
try:
    with open('$MCPS_FILE') as f:
        data = json.load(f)
    for name, mcp in data.get('mcpServers', {}).items():
        mcp_type = mcp.get('type', 'stdio')
        
        # For HTTP MCPs, use 'url' field and 'http' as install method
        if mcp_type == 'http':
            install_method = 'http'
            command = mcp.get('url', '')
        else:
            # For stdio MCPs, use installMethod (npx, uvx, pipx, etc.)
            install_method = mcp.get('installMethod', 'stdio')
            cmd = mcp.get('command', '')
            args = mcp.get('args', [])
            command = ' '.join([cmd] + args) if cmd else ''
        
        env = ','.join(mcp.get('env', []))
        print(f'{name}|{install_method}|{command}|{env}')
except Exception as e:
    pass
"
            ;;
        *)
            echo "  [error] No JSON tool available (install jq or python3)"
            return 1
            ;;
    esac
}

do_install_mcps() {
    echo ""
    echo "[dotfiles-claude] Installing MCP dependencies..."

    # Guard: claude must be installed
    if ! _is_installed; then
        echo "[dotfiles-claude] Claude Code not installed."
        echo "  Install it from: https://docs.anthropic.com/en/docs/claude-code"
        return 1
    fi

    # Guard: Termux not supported
    if _is_termux; then
        echo "[dotfiles-claude] Termux detected — skipping MCP install."
        return 0
    fi

    # Guard: registry must exist
    if [ ! -f "$MCPS_FILE" ]; then
        echo "[dotfiles-claude] MCP registry not found: $MCPS_FILE"
        return 1
    fi

    echo ""
    echo "  Installing MCPs from registry..."
    echo "  Source: $MCPS_FILE"
    echo ""

    # Read MCPs into a variable to avoid subshell issues with pipes
    mcp_list=$(_read_mcps_from_json)
    
    if [ -z "$mcp_list" ]; then
        echo "  [warn] No MCPs found in registry or failed to parse"
        return 1
    fi
    
    # Process each MCP line
    echo "$mcp_list" | while IFS= read -r line; do
        [ -z "$line" ] && continue
        _install_mcp "$line"
    done

    echo ""
    echo "[dotfiles-claude] MCP dependency check complete."
    echo ""
    echo "  To list configured MCPs:  claude mcp list"
    echo "  To add more MCPs:         claude mcp add <name> -- <command>"
    echo "  To remove an MCP:         claude mcp remove <name>"
    echo ""
}

# ─── Sync from OpenCode ───────────────────────────────────────────────────────

do_sync_from_opencode() {
    echo ""
    echo "[dotfiles-claude] Syncing MCPs from OpenCode config..."

    OPENCODE_CONFIG="$HOME/.config/opencode/opencode.jsonc"

    if [ ! -f "$OPENCODE_CONFIG" ]; then
        echo "[dotfiles-claude] OpenCode config not found at $OPENCODE_CONFIG"
        echo "  Run: stowme.sh first to set up OpenCode"
        return 1
    fi

    if ! _is_installed; then
        echo "[dotfiles-claude] Claude Code not installed."
        return 1
    fi

    tool=$(_json_tool)
    if [ "$tool" = "none" ]; then
        echo "[dotfiles-claude] Neither jq nor python3 found — cannot parse config."
        return 1
    fi

    echo ""
    echo "  Parsing $OPENCODE_CONFIG ..."
    echo ""

    # Parse OpenCode MCPs and add to Claude
    grep -v '^\s*//' "$OPENCODE_CONFIG" | jq -r '
        .mcp // {} | to_entries[] |
        select(.value.enabled == true) |
        "\(.key)|\(.value.type // "local")|\(.value.command | if type == "array" then join(" ") else . end)|\(.value.environment // {} | keys | join(","))"
    ' 2>/dev/null | while IFS= read -r line; do
        [ -z "$line" ] && continue

        mcp_name=$(echo "$line" | cut -d'|' -f1)
        mcp_type=$(echo "$line" | cut -d'|' -f2)
        mcp_command=$(echo "$line" | cut -d'|' -f3)
        mcp_env=$(echo "$line" | cut -d'|' -f4)

        # Skip remote MCPs for now
        if [ "$mcp_type" = "remote" ]; then
            echo "  [skip]    $mcp_name  (remote — add manually with --transport http)"
            continue
        fi

        # Check if already configured
        if _mcp_exists "$mcp_name"; then
            echo "  [ok]      $mcp_name  (already configured)"
            continue
        fi

        # Determine install type from command
        cmd_first=$(echo "$mcp_command" | awk '{print $1}')
        case "$cmd_first" in
            npx)  install_type="npx" ;;
            uvx)  install_type="uvx" ;;
            docker) install_type="docker" ;;
            *)    install_type="pipx" ;;
        esac

        _install_mcp "$mcp_name|$install_type|$mcp_command|$mcp_env"
    done

    echo ""
    echo "[dotfiles-claude] Sync complete."
    echo ""
}

# ─── List MCPs ────────────────────────────────────────────────────────────────

do_list() {
    if ! _is_installed; then
        echo "[dotfiles-claude] Claude Code not installed."
        return 1
    fi

    echo ""
    echo "[dotfiles-claude] Configured MCP servers:"
    echo ""
    claude mcp list
    echo ""
}

# ─── Add single MCP ───────────────────────────────────────────────────────────

do_add_mcp() {
    mcp_name="$1"
    scope="$2"

    if [ -z "$mcp_name" ]; then
        echo "[dotfiles-claude] Error: MCP name required"
        echo "Usage: dotfiles-claude add-$scope <mcp-name>"
        return 1
    fi

    # Check if MCP exists in registry
    mcp_data=$(_get_mcp_from_registry "$mcp_name")

    if [ -z "$mcp_data" ]; then
        echo "[dotfiles-claude] MCP '$mcp_name' not found in shared registry"
        echo ""
        echo "Available MCPs:"
        _list_available_mcps
        return 1
    fi

    # Extract MCP details
    json_tool=$(_json_tool)

    case "$json_tool" in
        jq)
            # Check if HTTP or stdio type
            transport_type=$(echo "$mcp_data" | jq -r '.type // "stdio"')
            mcp_env=$(echo "$mcp_data" | jq -r '(.env | select(. != null) | join(",")) // ""')
            
            if [ "$transport_type" = "http" ]; then
                mcp_type="http"
                mcp_url=$(echo "$mcp_data" | jq -r '.url // ""')
                mcp_command="$mcp_url"
            else
                # For stdio, use installMethod (npx, pipx, uvx, docker)
                mcp_type=$(echo "$mcp_data" | jq -r '.installMethod // "stdio"')
                mcp_command=$(echo "$mcp_data" | jq -r '[.command, .args[]?] | join(" ")')
            fi
            ;;
        python3)
            # Check transport type first
            transport_type=$(python3 -c "
import json
data = json.loads('$mcp_data')
print(data.get('type', 'stdio'))
")
            mcp_env=$(python3 -c "
import json
data = json.loads('$mcp_data')
env = data.get('env', [])
print(','.join(env) if env else '')
")
            if [ "$transport_type" = "http" ]; then
                mcp_type="http"
                mcp_url=$(python3 -c "
import json
data = json.loads('$mcp_data')
print(data.get('url', ''))
")
                mcp_command="$mcp_url"
            else
                # For stdio, use installMethod (npx, pipx, uvx, docker)
                mcp_type=$(python3 -c "
import json
data = json.loads('$mcp_data')
print(data.get('installMethod', 'stdio'))
")
                mcp_command=$(python3 -c "
import json
import sys
data = json.loads('$mcp_data')
cmd = data.get('command', '')
args = data.get('args', [])
print(' '.join([cmd] + args))
")
            fi
            ;;
        *)
            echo "[dotfiles-claude] Error: jq or python3 required to parse MCP registry"
            return 1
            ;;
    esac

    # Set scope and install
    SCOPE="$scope"

    echo "[dotfiles-claude] Adding '$mcp_name' ($scope scope)..."
    _install_mcp "$mcp_name|$mcp_type|$mcp_command|$mcp_env"
}

# ─── List available MCPs ──────────────────────────────────────────────────────

do_list_available() {
    echo ""
    echo "[dotfiles-claude] Shared MCP Registry"
    echo ""
    _list_available_mcps
    echo ""
    echo "To add an MCP:"
    echo "  dotfiles-claude add-local <name>   # Current project only"
    echo "  dotfiles-claude add-global <name>  # All projects (global)"
    echo ""
}

# ─── Instruction generator ────────────────────────────────────────────────────

do_generate_instructions() {
    echo ""
    echo "[dotfiles-claude] Generating CLAUDE.md from shared instructions..."
    
    # Determine dotfiles path
    if [ -n "${DOTFILES_PATH:-}" ]; then
        DOTFILES_DIR="$DOTFILES_PATH"
    elif [ -d "$HOME/.dotfiles" ]; then
        DOTFILES_DIR="$HOME/.dotfiles"
    else
        echo "[dotfiles-claude] Cannot locate dotfiles directory"
        echo "  Set DOTFILES_PATH or ensure ~/.dotfiles exists"
        return 1
    fi
    
    SHARED_INSTRUCTIONS="${DOTFILES_DIR}/shared/ai-agents/instructions/global.md"
    OUTPUT_FILE="$HOME/.claude/CLAUDE.md"
    
    # Check if source exists
    if [ ! -f "$SHARED_INSTRUCTIONS" ]; then
        echo "[dotfiles-claude] Shared instructions not found: $SHARED_INSTRUCTIONS"
        return 1
    fi
    
    # Create config directory if needed
    mkdir -p "$(dirname "$OUTPUT_FILE")"
    
    # Copy instructions
    cp "$SHARED_INSTRUCTIONS" "$OUTPUT_FILE"
    
    echo "  [done] Generated: $OUTPUT_FILE"
    echo "  Source: $SHARED_INSTRUCTIONS"
    echo ""
    echo "  This file is auto-generated. Edit the shared source instead:"
    echo "  $SHARED_INSTRUCTIONS"
    echo ""
}

# ─── Main ─────────────────────────────────────────────────────────────────────

usage() {
    echo "Usage: dotfiles-claude <command> [options]"
    echo ""
    echo "Commands:"
    echo "  install-mcps [--global|--local]   Install MCPs from registry (default: local)"
    echo "  add-global <mcp-name>             Add MCP to global config (all projects)"
    echo "  add-local <mcp-name>              Add MCP to local config (current project)"
    echo "  list-available                    List MCPs available in shared registry"
    echo "  list                              List currently configured MCPs"
    echo "  sync-from-opencode                Import MCPs from OpenCode config"
    echo "  generate-instructions             Generate CLAUDE.md from shared instructions"
    echo ""
    echo "Examples:"
    echo "  dotfiles-claude install-mcps              # Install all MCPs locally"
    echo "  dotfiles-claude install-mcps --global     # Install all MCPs globally"
    echo "  dotfiles-claude add-global github         # Add GitHub MCP globally"
    echo "  dotfiles-claude add-local context7        # Add Context7 MCP locally"
    echo "  dotfiles-claude generate-instructions     # Generate CLAUDE.md"
    echo ""
    echo "Environment variables are read from ~/.profile.local"
}

# Parse arguments
case "${1:-}" in
    install-mcps)
        # Check for scope flags
        if [ "${2:-}" = "--global" ]; then
            SCOPE="global"
            echo "[dotfiles-claude] Installing MCPs in GLOBAL scope (all projects)"
        elif [ "${2:-}" = "--local" ]; then
            SCOPE="local"
            echo "[dotfiles-claude] Installing MCPs in LOCAL scope (current project)"
        fi
        do_install_mcps
        ;;
    add-global)
        do_add_mcp "$2" "global"
        ;;
    add-local)
        do_add_mcp "$2" "local"
        ;;
    list-available)
        do_list_available
        ;;
    sync-from-opencode)
        do_sync_from_opencode
        ;;
    list)
        do_list
        ;;
    generate-instructions)
        do_generate_instructions
        ;;
    help|--help|-h)
        usage
        exit 0
        ;;
    *)
        usage
        exit 1
        ;;
esac

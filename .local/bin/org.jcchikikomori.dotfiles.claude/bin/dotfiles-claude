#!/bin/sh

set -eu

# dotfiles-claude — install Claude Code MCP dependencies
# https://docs.anthropic.com/en/docs/claude-code

# Source .profile.local for environment variables (MCP tokens, etc.)
if [ -f "$HOME/.profile.local" ]; then
    . "$HOME/.profile.local"
fi

CLAUDE_SETTINGS="$HOME/.claude/settings.json"

_is_installed() {
    command -v claude > /dev/null 2>&1
}

_detect_distro() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "${ID:-unknown}"
    else
        echo "unknown"
    fi
}

_is_termux() {
    [ -n "${PREFIX:-}" ] && echo "$PREFIX" | grep -q "com.termux"
}

# ─── JSON helpers ─────────────────────────────────────────────────────────────

_json_tool() {
    if command -v jq > /dev/null 2>&1; then
        echo "jq"
    elif command -v python3 > /dev/null 2>&1; then
        echo "python3"
    else
        echo "none"
    fi
}

# ─── MCP Registry ─────────────────────────────────────────────────────────────
# Define MCPs to install - same ones as OpenCode for consistency
# Format: name|type|command|env_keys
# Types: npx, uvx, pipx, docker, http

_get_mcp_registry() {
    cat <<'EOF'
context7|npx|npx -y @upstash/context7-mcp|
github|npx|npx -y @modelcontextprotocol/server-github|GITHUB_PERSONAL_ACCESS_TOKEN
stackoverflow-mcp|pipx|stackoverflow-mcp|STACK_EXCHANGE_API_KEY
web-forager|pipx|web-forager serve|
EOF
}

# ─── MCP helpers ──────────────────────────────────────────────────────────────

# Check if MCP is already configured in Claude
_mcp_exists() {
    mcp_name="$1"
    claude mcp list 2>/dev/null | grep -q "^$mcp_name " && return 0
    return 1
}

# Install a single MCP
_install_mcp() {
    line="$1"
    [ -z "$line" ] && return 0

    mcp_name=$(echo "$line" | cut -d'|' -f1)
    mcp_type=$(echo "$line" | cut -d'|' -f2)
    mcp_command=$(echo "$line" | cut -d'|' -f3)
    mcp_env=$(echo "$line" | cut -d'|' -f4)

    # Check if already configured
    if _mcp_exists "$mcp_name"; then
        echo "  [ok]      $mcp_name  (already configured)"
        _report_env "$mcp_name" "$mcp_env"
        return 0
    fi

    case "$mcp_type" in
        npx)
            if ! command -v npx > /dev/null 2>&1; then
                echo "  [warn]    $mcp_name  needs npx — install Node.js/npm first"
                return 0
            fi
            echo "  [add]     $mcp_name  via npx..."
            # Extract the package from npx command (npx -y <package>)
            npx_pkg=$(echo "$mcp_command" | sed 's/npx -y //')
            if _add_mcp_with_env "$mcp_name" "$mcp_command" "$mcp_env"; then
                echo "  [done]    $mcp_name  added"
            else
                echo "  [fail]    $mcp_name  failed to add"
            fi
            ;;
        uvx)
            if ! command -v uvx > /dev/null 2>&1; then
                echo "  [warn]    $mcp_name  needs uvx — install uv first"
                return 0
            fi
            echo "  [add]     $mcp_name  via uvx..."
            if _add_mcp_with_env "$mcp_name" "$mcp_command" "$mcp_env"; then
                echo "  [done]    $mcp_name  added"
            else
                echo "  [fail]    $mcp_name  failed to add"
            fi
            ;;
        pipx)
            # First ensure binary is installed
            binary_name=$(echo "$mcp_command" | awk '{print $1}')
            if ! command -v "$binary_name" > /dev/null 2>&1; then
                echo "  [pipx]    $mcp_name  installing '$binary_name' via pipx..."
                if pipx install "$binary_name" 2>&1 | sed 's/^/              /'; then
                    echo "  [done]    $mcp_name  binary installed"
                else
                    echo "  [fail]    $mcp_name  pipx install failed"
                    return 0
                fi
            fi
            # Now add to Claude
            echo "  [add]     $mcp_name  to Claude..."
            if _add_mcp_with_env "$mcp_name" "$mcp_command" "$mcp_env"; then
                echo "  [done]    $mcp_name  added"
            else
                echo "  [fail]    $mcp_name  failed to add"
            fi
            ;;
        http)
            echo "  [add]     $mcp_name  (HTTP server)..."
            if claude mcp add --transport http "$mcp_name" "$mcp_command" 2>&1 | sed 's/^/              /'; then
                echo "  [done]    $mcp_name  added"
            else
                echo "  [fail]    $mcp_name  failed to add"
            fi
            ;;
        *)
            echo "  [skip]    $mcp_name  (unknown type: $mcp_type)"
            ;;
    esac

    _report_env "$mcp_name" "$mcp_env"
}

# Add MCP with environment variables
_add_mcp_with_env() {
    mcp_name="$1"
    mcp_command="$2"
    mcp_env="$3"

    # Build env flags
    env_flags=""
    if [ -n "$mcp_env" ]; then
        old_ifs="$IFS"
        IFS=","
        for key in $mcp_env; do
            IFS="$old_ifs"
            [ -z "$key" ] && continue
            # Get value from environment
            val=""
            eval "val=\${${key}:-}"
            if [ -n "$val" ]; then
                env_flags="$env_flags -e $key=$val"
            fi
            IFS=","
        done
        IFS="$old_ifs"
    fi

    # Parse command into parts
    cmd_first=$(echo "$mcp_command" | awk '{print $1}')
    cmd_rest=$(echo "$mcp_command" | cut -d' ' -f2-)

    # Add MCP using claude CLI
    if [ -n "$env_flags" ]; then
        # shellcheck disable=SC2086
        claude mcp add $env_flags "$mcp_name" -- $mcp_command 2>&1 | sed 's/^/              /'
    else
        # shellcheck disable=SC2086
        claude mcp add "$mcp_name" -- $mcp_command 2>&1 | sed 's/^/              /'
    fi
}

# Report ENV status
_report_env() {
    mcp_name="$1"
    env_keys="$2"
    [ -z "$env_keys" ] && return

    echo "            ENV for $mcp_name:"
    old_ifs="$IFS"
    IFS=","
    for key in $env_keys; do
        IFS="$old_ifs"
        [ -z "$key" ] && continue
        val=""
        eval "val=\${${key}:-}"
        if [ -n "$val" ]; then
            echo "              $key  → set ✓"
        else
            echo "              $key  → NOT SET  ← export in shell or add to ~/.zshrc"
        fi
        IFS=","
    done
    IFS="$old_ifs"
}

# ─── MCP dependency installer ─────────────────────────────────────────────────

do_install_mcps() {
    echo ""
    echo "[dotfiles-claude] Installing MCP dependencies..."

    # Guard: claude must be installed
    if ! _is_installed; then
        echo "[dotfiles-claude] Claude Code not installed."
        echo "  Install it from: https://docs.anthropic.com/en/docs/claude-code"
        return 1
    fi

    # Guard: Termux not supported
    if _is_termux; then
        echo "[dotfiles-claude] Termux detected — skipping MCP install."
        return 0
    fi

    echo ""
    echo "  Installing MCPs from registry..."
    echo ""

    _get_mcp_registry | while IFS= read -r line; do
        [ -z "$line" ] && continue
        _install_mcp "$line"
    done

    echo ""
    echo "[dotfiles-claude] MCP dependency check complete."
    echo ""
    echo "  To list configured MCPs:  claude mcp list"
    echo "  To add more MCPs:         claude mcp add <name> -- <command>"
    echo "  To remove an MCP:         claude mcp remove <name>"
    echo ""
}

# ─── Sync from OpenCode ───────────────────────────────────────────────────────

do_sync_from_opencode() {
    echo ""
    echo "[dotfiles-claude] Syncing MCPs from OpenCode config..."

    OPENCODE_CONFIG="$HOME/.config/opencode/opencode.jsonc"

    if [ ! -f "$OPENCODE_CONFIG" ]; then
        echo "[dotfiles-claude] OpenCode config not found at $OPENCODE_CONFIG"
        echo "  Run: stowme.sh first to set up OpenCode"
        return 1
    fi

    if ! _is_installed; then
        echo "[dotfiles-claude] Claude Code not installed."
        return 1
    fi

    tool=$(_json_tool)
    if [ "$tool" = "none" ]; then
        echo "[dotfiles-claude] Neither jq nor python3 found — cannot parse config."
        return 1
    fi

    echo ""
    echo "  Parsing $OPENCODE_CONFIG ..."
    echo ""

    # Parse OpenCode MCPs and add to Claude
    grep -v '^\s*//' "$OPENCODE_CONFIG" | jq -r '
        .mcp // {} | to_entries[] |
        select(.value.enabled == true) |
        "\(.key)|\(.value.type // "local")|\(.value.command | if type == "array" then join(" ") else . end)|\(.value.environment // {} | keys | join(","))"
    ' 2>/dev/null | while IFS= read -r line; do
        [ -z "$line" ] && continue
        
        mcp_name=$(echo "$line" | cut -d'|' -f1)
        mcp_type=$(echo "$line" | cut -d'|' -f2)
        mcp_command=$(echo "$line" | cut -d'|' -f3)
        mcp_env=$(echo "$line" | cut -d'|' -f4)

        # Skip remote MCPs for now
        if [ "$mcp_type" = "remote" ]; then
            echo "  [skip]    $mcp_name  (remote — add manually with --transport http)"
            continue
        fi

        # Check if already configured
        if _mcp_exists "$mcp_name"; then
            echo "  [ok]      $mcp_name  (already configured)"
            continue
        fi

        # Determine install type from command
        cmd_first=$(echo "$mcp_command" | awk '{print $1}')
        case "$cmd_first" in
            npx)  install_type="npx" ;;
            uvx)  install_type="uvx" ;;
            docker) install_type="docker" ;;
            *)    install_type="pipx" ;;
        esac

        _install_mcp "$mcp_name|$install_type|$mcp_command|$mcp_env"
    done

    echo ""
    echo "[dotfiles-claude] Sync complete."
    echo ""
}

# ─── List MCPs ────────────────────────────────────────────────────────────────

do_list() {
    if ! _is_installed; then
        echo "[dotfiles-claude] Claude Code not installed."
        return 1
    fi

    echo ""
    echo "[dotfiles-claude] Configured MCP servers:"
    echo ""
    claude mcp list
    echo ""
}

# ─── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
    install-mcps)       do_install_mcps ;;
    sync-from-opencode) do_sync_from_opencode ;;
    list)               do_list ;;
    *)
        echo "Usage: dotfiles-claude {install-mcps|sync-from-opencode|list}"
        echo ""
        echo "  install-mcps:        Install common MCP servers (context7, github, etc.)"
        echo "  sync-from-opencode:  Import enabled MCPs from OpenCode config"
        echo "  list:                List configured MCP servers"
        exit 1
        ;;
esac
